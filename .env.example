# STORIS API
# Base URL is api.storis.com for hosted STORIS APIs.
STORIS_BASE_URL=https://api.storis.com
# API user credentials. Sent as HTTP Basic Auth to POST /api/authenticate/user.
STORIS_CLIENT_ID=
STORIS_CLIENT_SECRET=

# Shopify Admin API
# Store domain like quality-home-furniture.myshopify.com
SHOPIFY_STORE_DOMAIN=
# Admin API access token from a custom app with write_products scope.
SHOPIFY_ADMIN_TOKEN=
# Admin API version, e.g. 2025-01
SHOPIFY_API_VERSION=2025-01

# Optional: comma-separated STORIS category IDs to limit the sync.
# Matched case-insensitively against ProductData.category.categoryId and
# ProductData.category.categoryDescription. Defaults (14 IDs covering
# ~17.3k room-planner-relevant products) defined in src/config.ts.
# PRIORITY_CATEGORIES=UPHOLS,BEDRM,DINE,ACCENT,RECUPH,OCCAS,ENTER,YOUTH,HOMOFF,LEATH,RECLTR,BFRAME,BARS,LROOM
