{% comment %}
  QHF Room Planner — Phase 3 of the room visualization project.

  This section mounts the Konva.js planner built from /web in this repo.
  Before this section will render usefully, the Phase 2 STORIS→Shopify
  sync must have populated custom.width_in and custom.depth_in metafields,
  and those metafield definitions must be exposed to the Storefront API.

  See /shopify/README.md in the storis-api-inventory-to-shopify repo for
  full setup steps (uploading assets, creating the Storefront token,
  enabling storefront access on the metafield definitions).
{% endcomment %}

<link rel="stylesheet" href="{{ 'room-planner.css' | asset_url }}">

<div
  id="qhf-room-planner"
  data-shop-domain="{{ shop.permanent_domain }}"
  data-storefront-token="{{ section.settings.storefront_token }}"
  data-api-version="{{ section.settings.api_version | default: '2025-01' }}"
  style="min-height: {{ section.settings.min_height | default: 720 }}px;"
></div>

<script src="{{ 'room-planner.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Room Planner",
  "tag": "section",
  "class": "qhf-room-planner-section",
  "settings": [
    {
      "type": "header",
      "content": "Storefront API"
    },
    {
      "type": "text",
      "id": "storefront_token",
      "label": "Storefront API access token",
      "info": "Public Storefront API token from a custom app (Settings → Apps → Develop apps). Must have unauthenticated_read_product_listings scope and unauthenticated_read_metafields for the custom namespace."
    },
    {
      "type": "text",
      "id": "api_version",
      "label": "Storefront API version",
      "default": "2025-01"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "min_height",
      "label": "Minimum height (px)",
      "min": 480,
      "max": 1200,
      "step": 20,
      "default": 720
    }
  ],
  "presets": [
    {
      "name": "Room Planner",
      "category": "Page"
    }
  ]
}
{% endschema %}
