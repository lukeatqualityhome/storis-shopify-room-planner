{
  "name": "storis-api-inventory-to-shopify",
  "version": "0.1.0",
  "private": true,
  "description": "Sync STORIS product dimensions (width/depth/height) into Shopify product metafields. Phase 2 of qualityhome.com room planner.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "sync": "tsx src/index.ts",
    "sync:live": "tsx src/index.ts --live",
    "discover-categories": "tsx src/index.ts --discover-categories",
    "typecheck": "tsc --noEmit",
    "build": "tsc"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4"
  }
}
